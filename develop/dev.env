CHAT_HOST=chat
CLSI_HOST=clsi
DOWNLOAD_HOST=clsi-nginx
CONTACTS_HOST=contacts
DOCSTORE_HOST=docstore
DOCUMENT_UPDATER_HOST=document-updater
FILESTORE_HOST=filestore
GRACEFUL_SHUTDOWN_DELAY_SECONDS=0
HISTORY_V1_HOST=history-v1
HISTORY_REDIS_HOST=redis
LISTEN_ADDRESS=0.0.0.0
MONGO_HOST=mongo
MONGO_URL=mongodb://mongo/sharelatex?directConnection=true
NOTIFICATIONS_HOST=notifications
PROJECT_HISTORY_HOST=project-history
QUEUES_REDIS_HOST=redis
DSMP_REDIS_HOST=redis
REALTIME_HOST=real-time
REDIS_HOST=redis
SESSION_SECRET=foo
V1_HISTORY_HOST=history-v1
WEBPACK_HOST=webpack
WEB_API_PASSWORD=overleaf
WEB_API_USER=overleaf
WEB_HOST=web

# AI assistant (Claude Code) — lightweight in-process subprocess.
# AI_ASSISTANT_TOKEN_KEY: 32-byte hex key used to encrypt per-user OAuth
# tokens at rest in Mongo. Generate with: openssl rand -hex 32
AI_ASSISTANT_TOKEN_KEY=
# Path to the claude CLI binary inside the web container. Empty disables
# the feature.
AI_ASSISTANT_CLAUDE_BIN=claude
# Idle timeout before an inactive subprocess is killed (ms).
AI_ASSISTANT_IDLE_MS=600000
