# Overleaf + Claude Code AI Assistant environment.
# Copy to dev.env and fill in the values, or run ../bin/setup.sh to auto-generate.

# Path to the claude CLI binary inside the web container (baked into image).
AI_ASSISTANT_CLAUDE_BIN=claude

# Encryption key for Claude OAuth tokens stored in MongoDB.
# Auto-generated by bin/setup.sh — keep this secret.
AI_ASSISTANT_TOKEN_KEY=

# How long (ms) before idle Claude sessions are killed. Default 10 min.
AI_ASSISTANT_IDLE_MS=600000

# Public URL users visit in their browser (include port if non-80).
# Used for WebSocket connections and callback URLs.
PUBLIC_URL=http://192.168.0.6:8082

# CLSI download host — Docker container name or IP (no scheme).
DOWNLOAD_HOST=clsi-nginx
